# ─── Database ──────────────────────────────────────────────────────────────────

POSTGRES_USER=kb

# [REQUIRED] openssl rand -base64 24 | tr -d '=\n'
POSTGRES_PASSWORD=

POSTGRES_DB=knowledge_base

# ─── Application secrets ───────────────────────────────────────────────────────

# [REQUIRED] openssl rand -base64 48 | tr -d '=\n'
JWT_SECRET=

# [REQUIRED] openssl rand -base64 32 | tr '+/' '-_'
FERNET_KEY=

# ─── First admin account ───────────────────────────────────────────────────────

# [REQUIRED] Admin login email — created automatically on first startup
ADMIN_EMAIL=

# [REQUIRED] openssl rand -base64 12 | tr -d '=\n'
ADMIN_PASSWORD=

# ─── Optional ──────────────────────────────────────────────────────────────────

# [optional] default: development — set to production to enable production-mode settings
# APP_ENV=production

# [optional] default: latest — pin a specific image tag to prevent auto-upgrades on pull
# APP_VERSION=1.2.0
