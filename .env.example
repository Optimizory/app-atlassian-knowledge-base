# ─── Database ──────────────────────────────────────────────────────────────────

POSTGRES_USER=kb

# [REQUIRED] python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=

POSTGRES_DB=knowledge_base

# ─── Application secrets ───────────────────────────────────────────────────────

# [REQUIRED] python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# [REQUIRED] python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── First admin account ───────────────────────────────────────────────────────

# [REQUIRED] Admin login email — created automatically on first startup
ADMIN_EMAIL=

# [REQUIRED] python3 -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_PASSWORD=

# ─── Optional ──────────────────────────────────────────────────────────────────

# [optional] default: development — set to production to enable production-mode settings
# APP_ENV=production

# [optional] default: latest — pin a specific image tag to prevent auto-upgrades on pull
# APP_VERSION=1.2.0
